{
  "skillListingBudgetFraction": 0.1,
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "true",
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "128000",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-8"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Skill(*)"
    ],
    "defaultMode": "auto"
  },
  "model": "claude-opus-4-8",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/krvij/.claude/hooks/guard-destructive.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/krvij/.claude/hooks/guard-gitignore.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/krvij/.claude/hooks/prettier.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/krvij/.claude/hooks/init-env.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/krvij/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "data@claude-plugins-official": true,
    "data-engineering@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      },
      "autoUpdate": true
    }
  },
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "theme": "dark-daltonized",
  "agentPushNotifEnabled": true
}
